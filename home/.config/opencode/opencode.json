{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "figma": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    },
    "mcp-debugger": {
      "command": [
        "npx",
        "-y",
        "github:metruzanca/mcp-debugger"
      ],
      "enabled": false,
      "type": "local"
    },
    "railway": {
      "command": [
        "railway",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": "allow",
  "theme": "system"
}